[Unit]
Description=furaffinity_scrape

[Service]
Type=simple
WorkingDirectory={{var_fascrape_remote_base_directory}}
ExecStart=python3 {{var_fascrape_remote_base_directory}}/furaffinity_scrape.pex --config {{var_fascrape_remote_base_directory}}/furaffinity_scrape_config.hocon scrape_submissions
ExecStopPost=/bin/echo "Result: ${SERVICE_RESULT}, Code: ${EXIT_CODE}, Status: ${EXIT_STATUS}"
Restart=on-failure

[Install]
WantedBy=default.target